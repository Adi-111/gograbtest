generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model ExpiredEvent {
  id             Int         @id @default(autoincrement())
  
  // Relations
  case           Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId         Int         
  
  
  
  issueEventId   Int?        
  
  // Snapshots
  customerId     Int         // Denormalized for quick analytics grouping
  lastAssignedTo CaseHandler
  totalMessages  Int         @default(0)
  
  // Timing details
  timerSetAt     DateTime    // When the countdown started
  expiredAt      DateTime    // When the job marked it as expired
  lastMessageAt  DateTime?   // Time of the very last message in the chat
  
  // Traceability
  lastBotNodeId    String?   // Crucial: The specific step they got stuck on
  wasAgentNotified Boolean   @default(false)

  createdAt      DateTime    @default(now())

  @@index([caseId])
  @@index([issueEventId])
  @@index([createdAt])
  @@index([lastBotNodeId]) // Recommended: helps find "bottleneck" nodes
}


model Machine {
  machine_id                            String    @id
  machine_name                          String
  location                              String
  description                           String
  rating                                String
  machine_status                        Boolean
  machine_type                          String
  machine_capacity                      Int
  total_coils                           Int
  password                              String
  date_created                          DateTime
  left_units                            Int
  last_refill_time                      DateTime?
  last_refill_by                        String?
  last_refill_availability              String?
  availability                          String?
  last_transaction                      DateTime?
  accumulated_downtime                  String?
  time_difference_from_last_transaction String?
  last_report_time                      DateTime?
  refill_report_time_difference         String?
  variety_score                         String?
  latitude                              Float?
  longitude                             Float?
  createdAt                             DateTime  @default(now())
  updatedAt                             DateTime
}

model Bot {
  name      String    @default("ChatBot")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  id        Int       @id @default(autoincrement())
  Case      Case[]
  messages  Message[]
}

model QuickReplies {
  id           Int       @id @unique @default(autoincrement())
  flowNodeType ReplyType
  header       Json?
  body         Json?
  footer       Json?
  action       Json?
  replies      Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BotReplies {
  nodeId       String    @unique
  flowNodeType ReplyType
  header       Json?
  body         Json?
  footer       Json?
  action       Json?
  replies      Json?
  botId        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model User {
  firstName               String
  lastName                String
  email                   String                    @unique
  password                String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  id                      Int                       @id @default(autoincrement())
  role                    UserRole?                 @default(Unknown)
  cases                   Case[]
  dailyUserMessageSummary DailyUserMessageSummary[]
  failedMsgEvent          FailedMsgEvent[]
  messages                Message[]
  notes                   Note[]
  sessions                Session[]
  statusEvent             StatusEvent[]
  tags                    Tag[]                     @relation("UserTags")
}

model DailyUserMessageSummary {
  id             Int       @id @default(autoincrement())
  userId         Int
  date           DateTime  @db.Date
  firstMessageId Int?
  lastMessageId  Int?
  firstTimestamp DateTime?
  lastTimestamp  DateTime?
  totalMessages  Int       @default(0)
  activeDuration Int?
  firstText      String?
  lastText       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  firstMessage   Message?  @relation("SummaryFirstMessage", fields: [firstMessageId], references: [id])
  lastMessage    Message?  @relation("SummaryLastMessage", fields: [lastMessageId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model Session {
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model WhatsAppCustomer {
  phoneNo         String    @unique
  createdAt       DateTime  @default(now())
  name            String
  id              Int       @id @default(autoincrement())
  profileImageUrl String
  cases           Case[]
  message         Message[]
}

model Case {
  status         Status           @default(INITIATED)
  assignedTo     CaseHandler      @default(BOT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  id             Int              @id @default(autoincrement())
  customerId     Int
  userId         Int?
  botId          Int?
  unread         Int?
  timer          DateTime?
  lastBotNodeId  String?
  meta           Json?
  isNewCase      Boolean          @default(true)
  currentIssueId Int?
  lastMessageAt  DateTime?
  bot            Bot?             @relation(fields: [botId], references: [id])
  customer       WhatsAppCustomer @relation(fields: [customerId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  failedMsgEvent FailedMsgEvent[]
  issueEvents    IssueEvent[]
  expiredEvents  ExpiredEvent[]
  messages       Message[]
  notes          Note[]
  statusEvent    StatusEvent[]
  tags           Tag[]            @relation("CaseTags")

  @@index([status])
  @@index([customerId])
}

model IssueEvent {
  id                Int              @id @default(autoincrement())
  caseId            Int
  customerId        Int
  userId            Int?
  status            IssueEventStatus @default(OPEN)
  isActive          Boolean          @default(true)
  openedAt          DateTime         @default(now())
  closedAt          DateTime?
  machineName       String?
  issueType         IssueType        @default(OTHER)
  refundMode        RefundMode?
  refundAmountMinor Int?
  resolutionNotes   String?
  agentCalledAt     DateTime?
  agentLinkedAt     DateTime?
  endTimeAt         DateTime?
  created_at        DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  falsePositive     Boolean?
  machine_id        String?
  utr               String?
  coil              Int?
  orderTime         String?
  agentRating       Int?
  case              Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@index([caseId])
  @@index([status, isActive])
  @@index([issueType])
  @@index([userId, status, closedAt])
}

model StatusEvent {
  id             Int      @id @default(autoincrement())
  caseId         Int
  userId         Int?
  previousStatus Status
  newStatus      Status
  timestamp      DateTime @default(now())
  case           Case     @relation(fields: [caseId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])

  @@index([caseId])
}

model FailedMsgEvent {
  id        Int      @id @default(autoincrement())
  caseId    Int
  userId    Int
  text      String
  timestamp DateTime @default(now())
  tries     Int
  messageId Int
  case      Case     @relation(fields: [caseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([caseId])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  caseId    Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Tag {
  id        Int      @id @default(autoincrement())
  text      String   @unique
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserTags", fields: [userId], references: [id])
  cases     Case[]   @relation("CaseTags")
}

model Message {
  type               MessageType
  replyType          ReplyType?
  senderType         SenderType
  text               String?
  recipient          String?
  timestamp          DateTime                  @default(now())
  waMessageId        String?
  context            Json?
  systemStatus       SystemMessageStatus?
  error              Json?
  whatsAppCustomerId Int?
  id                 Int                       @id @default(autoincrement())
  userId             Int?
  botId              Int?
  parentMessageId    Int?
  caseId             Int?
  issueEventId       Int?
  contacts           Contact[]
  firstInSummaries   DailyUserMessageSummary[] @relation("SummaryFirstMessage")
  lastInSummaries    DailyUserMessageSummary[] @relation("SummaryLastMessage")
  interactive        Interactive?
  location           Location?
  media              Media?
  bot                Bot?                      @relation(fields: [botId], references: [id])
  case               Case?                     @relation(fields: [caseId], references: [id])
  issueEvent         IssueEvent?               @relation(fields: [issueEventId], references: [id])
  parentMessage      Message?                  @relation("MessageReplies", fields: [parentMessageId], references: [id])
  replies            Message[]                 @relation("MessageReplies")
  user               User?                     @relation(fields: [userId], references: [id])
  WhatsAppCustomer   WhatsAppCustomer?         @relation(fields: [whatsAppCustomerId], references: [id])

  @@index([senderType])
  @@index([recipient])
  @@index([timestamp])
  @@index([type])
  @@index([caseId])
  @@index([caseId, timestamp(sort: Desc)])
  @@index([issueEventId, timestamp])
}

model Media {
  url       String
  mimeType  String
  caption   String?
  fileName  String?
  size      Int?
  duration  Int?
  height    Int?
  width     Int?
  id        Int      @id @default(autoincrement())
  messageId Int?     @unique
  waMediaId String?
  message   Message? @relation(fields: [messageId], references: [id])
}

model Location {
  latitude  Float
  longitude Float
  name      String?
  address   String?
  url       String?
  accuracy  Float?
  id        Int      @id @default(autoincrement())
  messageId Int?     @unique
  message   Message? @relation(fields: [messageId], references: [id])
}

model Product {
  product_id           String   @id @unique
  product_name         String
  description          String?
  image                String
  category             String
  product_price        Int
  brand_name           String
  created_at           DateTime @default(now())
  hsn_code             String?
  bar_code             String?
  is_active            Boolean  @default(true)
  moq                  Int
  zoho_item_id         String
  purchase_rate        Float
  inter_state_tax_rate Float
  intra_state_tax_rate Float
  product_type         String?
  markdown_percentage  Float
}

model Contact {
  name      Json?
  phones    Json
  emails    Json?
  addresses Json?
  org       Json?
  birthday  DateTime?
  urls      Json?
  id        Int       @id @default(autoincrement())
  messageId Int?
  message   Message?  @relation(fields: [messageId], references: [id])
}

model Interactive {
  type         String
  header       Json?
  body         Json?
  footer       Json?
  action       Json
  parameters   Json?
  userResponse Json?
  id           Int      @id @default(autoincrement())
  messageId    Int?     @unique
  message      Message? @relation(fields: [messageId], references: [id])
}

model CustomerOrderDetails {
  id               Int      @id @default(autoincrement())
  customerId       Int
  coils            String[]
  productIds       String[]
  dispenseStatuses String[]
  machine_id       String?
  verdict          String?
  orderTime        DateTime
  created_at       DateTime @default(now())
}

model DailyAnalytics {
  id                    Int      @id @default(autoincrement())
  date                  DateTime @unique @db.Date
  casesOpened           Int      @default(0)
  casesPending          Int      @default(0)
  casesSolved           Int      @default(0)
  casesSolvedByOperator Int      @default(0)
  casesSolvedByBot      Int      @default(0)
  casesExpired          Int      @default(0)
  casesProcessing       Int      @default(0)
  missedChats           Int      @default(0)
  avgCaseDuration       Float?   @default(0)
  totalCaseDuration     Float?   @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([date])
}

model TagAnalytics {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  tagText   String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, tagText])
  @@index([date])
  @@index([tagText])
}

model OverallAnalytics {
  id                    Int      @id @default(autoincrement())
  totalCases            Int      @default(0)
  casesProcessing       Int      @default(0)
  casesSolved           Int      @default(0)
  casesSolvedByBot      Int      @default(0)
  casesSolvedByOperator Int      @default(0)
  casesExpired          Int      @default(0)
  casesOpen             Int      @default(0)
  lastUpdated           DateTime @default(now())

  @@map("overall_analytics")
}

model HourlyAnalytics {
  id                    Int      @id @default(autoincrement())
  datetime              DateTime @unique
  casesOpened           Int      @default(0)
  casesPending          Int      @default(0)
  casesSolved           Int      @default(0)
  casesSolvedByOperator Int      @default(0)
  casesSolvedByBot      Int      @default(0)
  casesExpired          Int      @default(0)
  casesProcessing       Int      @default(0)
  missedChats           Int      @default(0)
  avgCaseDuration       Float?   @default(0)
  totalCaseDuration     Float?   @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([datetime])
}

enum ReplyType {
  InteractiveList
  InteractiveButtons
  Question
  Message
  Media
}

enum UserRole {
  Admin
  Agent
  Unknown
}

enum IssueEventStatus {
  OPEN
  CLOSED
}

enum IssueType {
  REFUND
  MACHINE_OFFLINE
  MACHINE_NOT_WORKING
  FEEDBACK
  MACHINE_NOT_REFILLED
  OTHER
  INACTIVE
}

enum RefundMode {
  AUTO
  MANUAL
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  CONTACT
  LOCATION
  INTERACTIVE
  SYSTEM
  LIST_REPLY
  BUTTON_REPLY
}

enum SenderType {
  USER
  CUSTOMER
  BOT
}

enum SystemMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
  UPDATED
  DISABLED
}

enum Status {
  INITIATED
  BOT_HANDLING
  ASSIGNED
  PROCESSING
  SOLVED
  UNSOLVED
}

enum CaseHandler {
  USER
  BOT
}
